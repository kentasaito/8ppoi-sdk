{
  "lint": {
    "exclude": ["console/*/bundle.js", "cartridges/*/*/*/bundle.js"]
  },
  "fmt": {
    "exclude": ["console/*/bundle.js", "cartridges/*/*/*/bundle.js"]
  },
  "tasks": {
    "lint": "deno lint",
    "fmt": "deno fmt",
    "validate": "deno run --allow-read utilities/validate/index.js",
    "bundle": "deno run --allow-env --allow-read --allow-write utilities/bundle/index.js"
  },
  "lock": false
}
